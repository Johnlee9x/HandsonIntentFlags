<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Activity Info -->
        <TextView
            android:id="@+id/tvInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#E3F2FD"
            android:fontFamily="monospace"
            android:padding="12dp"
            android:textSize="13sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="#BDBDBD" />

        <!-- Section: Basic Flags -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔹 BASIC FLAGS"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnNoFlag"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start A (No Flag)"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btnSingleTop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start A → FLAG_ACTIVITY_SINGLE_TOP"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btnNewTask"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start A → FLAG_ACTIVITY_NEW_TASK"
            android:textAllCaps="false" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="#BDBDBD" />

        <!-- Section: Clear Flags -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔹 CLEAR FLAGS"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnClearTop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start A → FLAG_ACTIVITY_CLEAR_TOP"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btnClearTopSingleTop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start A → CLEAR_TOP + SINGLE_TOP"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btnClearTask"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start A → NEW_TASK + CLEAR_TASK"
            android:textAllCaps="false" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="#BDBDBD" />

        <!-- Section: Other Flags -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔹 OTHER FLAGS"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnNoHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start A → FLAG_ACTIVITY_NO_HISTORY"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btnReorderToFront"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start A → FLAG_ACTIVITY_REORDER_TO_FRONT"
            android:textAllCaps="false" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="#BDBDBD" />

        <!-- Section: Build Stack Then Test -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔹 BUILD STACK (Main → A → B → C)"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnBuildStack"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start chain: A → B → C (no flags)"
            android:textAllCaps="false" />

    </LinearLayout>
</ScrollView>